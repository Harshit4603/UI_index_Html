{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}

{
  "outputDirectory": ".",
  "routes": [
    { "src": "/product-catalogue.pdf", "dest": "/product-catalogue.pdf" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
